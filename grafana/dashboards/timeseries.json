{
  "title": "Applications: Time Series",
  "uid": "aao-timeseries",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5m",
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Cumulative Applications",
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "jobs"
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "always",
            "pointSize": 5,
            "spanNulls": true
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "time series",
          "timeColumns": [
            "time"
          ],
          "queryText": "SELECT CAST(strftime('%s', applied_at) AS INTEGER) AS time, (SELECT COUNT(*) FROM applications a2 WHERE a2.applied_at IS NOT NULL AND a2.applied_at <= a.applied_at) AS value FROM applications a WHERE applied_at IS NOT NULL ORDER BY applied_at",
          "rawQueryText": "SELECT CAST(strftime('%s', applied_at) AS INTEGER) AS time, (SELECT COUNT(*) FROM applications a2 WHERE a2.applied_at IS NOT NULL AND a2.applied_at <= a.applied_at) AS value FROM applications a WHERE applied_at IS NOT NULL ORDER BY applied_at"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "Applications per Week",
      "id": 2,
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "jobs"
      },
      "options": {
        "orientation": "auto",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "barRadius": 0,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "none",
            "axisPlacement": "auto"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "table",
          "queryText": "SELECT strftime('%Y-W%W', applied_at) AS Week, COUNT(*) AS Applications FROM applications WHERE applied_at IS NOT NULL GROUP BY Week ORDER BY Week",
          "rawQueryText": "SELECT strftime('%Y-W%W', applied_at) AS Week, COUNT(*) AS Applications FROM applications WHERE applied_at IS NOT NULL GROUP BY Week ORDER BY Week"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "Response Time per Company (days from applied to next status)",
      "id": 3,
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "jobs"
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "barRadius": 0,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "none",
            "axisPlacement": "auto"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "table",
          "queryText": "SELECT a.company AS Company, CAST((julianday(MIN(e2.occurred_at)) - julianday(a.applied_at)) AS INTEGER) AS Days FROM applications a JOIN status_events e2 ON e2.application_id = a.id AND e2.status != 'applied' WHERE a.applied_at IS NOT NULL GROUP BY a.id ORDER BY Days",
          "rawQueryText": "SELECT a.company AS Company, CAST((julianday(MIN(e2.occurred_at)) - julianday(a.applied_at)) AS INTEGER) AS Days FROM applications a JOIN status_events e2 ON e2.application_id = a.id AND e2.status != 'applied' WHERE a.applied_at IS NOT NULL GROUP BY a.id ORDER BY Days"
        }
      ]
    }
  ]
}
